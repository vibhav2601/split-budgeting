# Copy to .env.local and fill in.

# OpenAI API key for GPT vision + merchant matching.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the GPT model. Must support vision.
# OPENAI_MODEL=gpt-4o

# Splitwise personal API key.
# Generate at https://secure.splitwise.com/oauth_clients (free account is fine).
SPLITWISE_API_KEY=

# Your first name as it appears in Splitwise CSV exports (for share detection).
# Only needed for CSV import; API import uses your user id.
SPLITWISE_MY_NAME=

# Optional: override the SQLite file path.
# BUDGET_DB_PATH=./data/budget.db
